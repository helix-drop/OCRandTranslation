# 本地数据文件夹 - 不同步到GitHub
local_data/
data/
example/

# 开发进度文档（个人使用，不同步）
PROGRESS.md
DEV.md

# 系统文件
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 虚拟环境
.venv/
venv/
ENV/
env/

# IDE和编辑器配置
.claude/
.qoder/
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# 日志文件
*.log

